2027*PROCEDURE &ECREE(NOMFI,NOM,ENR)            ;* CRÉÉ UN NOUVEL ENREGISTREMENT CLÉ=NOM
2028*PROCEDURE &EMODI(NOMFI,NOM,ENR)            ;* MODIFIE L'ENREGISTREMENT CLÉ=NOM
2029*PROCEDURE &ESUPR(NOMFI,NOM);* -> ENR       ;* SUPPRIME L'ENREGISTREMENT CLÉ=NOM
2030*PROCEDURE &ELIRE(NOMFI,NOM);* -> ENR       ;* CHERCHE L'ENREGISTREMENT CLÉ=NOM
2031*PROCEDURE &EINDX(NOMFI,NOM);* -> INDEX     ;* RETOURNE L'INDEX DE L'ENREGISTREMENT CLÉ=NOM
2032*PROCEDURE &IZERO(NOMFI);* -> INDEX         ;* RETOURNE UN INDEX SUR LE PREMIER ENREGISTREMENT (INDEXÉ, TRIÉ)
2033*PROCEDURE &ISUIV(NOMFI,INDEX);* -> INDEX   ;* RETOURNE UN INDEX SUR L'ENREGISTREMENT SUIVANT (OU 0 POUR FIN DE FICHIER)
2034*PROCEDURE &IPREC(NOMFI,INDEX);* -> INDEX   ;* RETOURNE UN INDEX SUR L'ENREGISTREMENT PRÉCÉDENT (OU 0 POUR DEBUT DE FICHIER)
2035*PROCEDURE &ILIRE(NOMFI,INDEX);* -> ENR     ;* LIS L'ENREGISTREMENT à L'INDEX
2036*PROCEDURE &IMODI(NOMFI,INDEX,ENR)          ;* MODIFIE L'ENREGISTREMENT à L'INDEX
2037*PROCEDURE &ISUPR(NOMFI,INDEX);* -> ENR     ;* SUPRIME L'ENREGISTREMENT à L'INDEX
